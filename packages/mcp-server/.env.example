# NeuroStream MCP Server Configuration

# Required — Supabase Edge Functions base URL
NEUROSTREAM_API_URL=https://your-supabase-url/functions/v1

# Required — SDK API Key (ns_live_...)
NEUROSTREAM_API_KEY=ns_live_your_key_here

# Required — Gateway base URL (Next.js app)
NEUROSTREAM_GATEWAY_URL=http://localhost:3000