# NeuroStream Platform — Development defaults (committed to Git)
# Non-sensitive values only! Secrets go in .env.development.local
#
# Loading order: .env → .env.local → .env.development → .env.development.local
# Later files override earlier ones.
#
# NOTE: Agent and Provider are external services with their own .env files.
#       Do NOT put Agent/Provider vars here.

# ── Blockchain (Hardhat local) ────────────────────────────
MONAD_RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
PAYMENT_TOKEN_DECIMALS=6
# Contract addresses — update in .env.development.local after deploy
PAYMENT_TOKEN_ADDRESS=
ESCROW_CONTRACT_ADDRESS=

