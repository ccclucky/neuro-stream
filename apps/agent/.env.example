# NeuroStream Agent — Environment Variables
# Copy this file to .env and fill in your values.

# ── Required ───────────────────────────────────────────────
NEUROSTREAM_API_KEY=                    # API Key from Agent Developer Panel
NEUROSTREAM_PRIVATE_KEY=                # Agent wallet private key
GEMINI_API_KEY=                         # Google Gemini API Key

# ── Gateway ────────────────────────────────────────────────
NEUROSTREAM_GATEWAY_URL=http://localhost:3000

# ── SDK (env fallback — set once per deployment) ───────────
NEUROSTREAM_API_URL=https://uppsdjgmgfwbknbzvhby.supabase.co/functions/v1
ESCROW_CONTRACT_ADDRESS=                # From deploy output
PAYMENT_TOKEN_ADDRESS=                  # From deploy output
MONAD_RPC_URL=http://127.0.0.1:8545    # Default: Hardhat local
PAYMENT_TOKEN_DECIMALS=6
