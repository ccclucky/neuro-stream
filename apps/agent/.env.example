# NeuroStream Agent — Environment Variables
# Copy this file to .env and fill in your values.

# ── NeuroStream SDK ──────────────────────────────────────
# Required: API Key from the Agent Developer Panel
NEUROSTREAM_API_KEY=

# Required: Your wallet private key (exported from Agent Developer Panel)
NEUROSTREAM_PRIVATE_KEY=

# Optional: Override defaults
# NEUROSTREAM_API_URL=https://uppsdjgmgfwbknbzvhby.supabase.co/functions/v1
# MONAD_RPC_URL=http://127.0.0.1:8545
# ESCROW_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# ── Provider (local dev only) ────────────────────────────
PROVIDER_API_URL=http://localhost:3001

# ── Gemini AI ────────────────────────────────────────────
GEMINI_API_KEY=
