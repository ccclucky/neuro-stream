# NeuroStream Provider — Environment Variables
# Copy this file to .env and fill in your values.

# ── Blockchain ──────────────────────────────────────────
# Required: Escrow contract address
ESCROW_CONTRACT_ADDRESS=

# Required: Provider wallet address (receives payments)
PROVIDER_WALLET_ADDRESS=

# Required: Provider private key (for claiming payments)
PROVIDER_PRIVATE_KEY=

# Optional: Override defaults
# MONAD_RPC_URL=http://127.0.0.1:8545
# PROVIDER_PORT=3001
