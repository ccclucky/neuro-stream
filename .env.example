# NeuroStream Platform — Environment Variable Reference
#
# ┌────────────────────┬──────────┬──────────────────────────────────┐
# │ File               │ Git      │ Contents                         │
# ├────────────────────┼──────────┼──────────────────────────────────┤
# │ .env               │ Committed│ Universal defaults (all envs)    │
# │ .env.development   │ Committed│ Dev non-sensitive (URLs, IDs)    │
# │ .env.production    │ Committed│ Prod non-sensitive (URLs, IDs)   │
# │ .env.local         │ Ignored  │ Secrets + contract addresses     │
# └────────────────────┴──────────┴──────────────────────────────────┘
#
# Loading order (dotenv-cli -c <env>):
#   .env -> .env.local -> .env.<env> -> .env.<env>.local
#
# NOTE: Agent and Provider are EXTERNAL services.
#       Their env vars live in apps/agent/.env and apps/provider/.env respectively.

# ═══════════════════════════════════════════════════════════
# .env — Universal defaults (committed)
# ═══════════════════════════════════════════════════════════

PAYMENT_TOKEN_DECIMALS=6                # Token decimals (6 for USDC)
PLATFORM_FEE_BPS=200                    # Platform fee in basis points (200 = 2%, max 5000)
PROVIDER_PORT=3001                      # Provider HTTP server port
REPORT_GAS=false                        # Enable Hardhat gas reporter

# ═══════════════════════════════════════════════════════════
# .env.development / .env.production — Per-env config (committed)
# ═══════════════════════════════════════════════════════════

MONAD_RPC_URL=                          # Blockchain RPC (Hardhat: http://127.0.0.1:8545, Monad: https://testnet-rpc.monad.xyz/)
CHAIN_ID=                               # Chain ID (31337=Hardhat, 10143=Monad Testnet)
SUPABASE_URL=                           # Supabase project URL
SUPABASE_ANON_KEY=                      # Supabase anonymous key (public by design)
PRIVY_APP_ID=                           # Privy application ID
GATEWAY_WALLET_ADDRESS=                 # Gateway wallet address (public, dev only)

# Next.js public vars (duplicate of above with NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_MONAD_RPC_URL=
NEXT_PUBLIC_CHAIN_ID=
NEXT_PUBLIC_PAYMENT_TOKEN_DECIMALS=6
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_PRIVY_APP_ID=

# ═══════════════════════════════════════════════════════════
# .env.local — Secrets + contract addresses (gitignored, NEVER commit!)
# ═══════════════════════════════════════════════════════════

# Contract addresses (fill after deploy, need NEXT_PUBLIC_ duplicates for frontend)
PAYMENT_TOKEN_ADDRESS=
ESCROW_CONTRACT_ADDRESS=
NEXT_PUBLIC_PAYMENT_TOKEN_ADDRESS=
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=

# Platform fee recipient (defaults to deployer if empty)
PLATFORM_ADDRESS=

# Private keys
DEPLOYER_PRIVATE_KEY=                   # Wallet private key for contract deployment
GATEWAY_PRIVATE_KEY=                    # Gateway wallet private key

# Supabase secrets (match current -c environment)
SUPABASE_SERVICE_ROLE_KEY=              # Supabase service role key (admin access)
SUPABASE_DB_URL=                        # PostgreSQL connection string

# Privy
PRIVY_APP_SECRET=                       # Privy application secret
