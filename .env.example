# NeuroStream — Environment Variable Reference
#
# Loading order (via dotenv-cli -c):
#   .env → .env.local → .env.<environment> → .env.<environment>.local
#   Later files override earlier ones.
#
# Files committed to Git:
#   .env                  Shared non-sensitive defaults
#   .env.development      Development defaults (local URLs, test addresses)
#   .env.production       Production template (empty placeholders)
#
# Files NOT committed (add your secrets here):
#   .env.local            Local overrides for all environments
#   .env.development.local  Local overrides for development
#   .env.production.local   Local overrides for production
#
# Usage:
#   pnpm dev      → loads with -c development
#   pnpm build    → loads with -c production
#   pnpm test     → loads with -c development

# ── Blockchain ──────────────────────────────────────────────
MONAD_RPC_URL=http://127.0.0.1:8545         # Monad / Hardhat RPC endpoint
ESCROW_CONTRACT_ADDRESS=                     # Deployed Escrow contract address

# ── Deployer (SECRET) ──────────────────────────────────────
DEPLOYER_PRIVATE_KEY=                        # SECRET — wallet private key for contract deployment

# ── Provider Service ───────────────────────────────────────
PROVIDER_PORT=3001                           # Provider API listen port
PROVIDER_API_URL=http://localhost:3001       # Provider API base URL
PROVIDER_WALLET_ADDRESS=                     # Provider's wallet address
PROVIDER_PRIVATE_KEY=                        # SECRET — Provider's wallet private key

# ── Supabase ───────────────────────────────────────────────
SUPABASE_URL=                                # Supabase project URL
SUPABASE_ANON_KEY=                           # Supabase anonymous key
SUPABASE_SERVICE_ROLE_KEY=                   # SECRET — Supabase service role key
SUPABASE_DB_URL=                             # SECRET — PostgreSQL connection string (Dashboard → Settings → Database → Connection string)

# ── Privy ──────────────────────────────────────────────────
PRIVY_APP_ID=                                # Privy application ID
PRIVY_APP_SECRET=                            # SECRET — Privy application secret

# ── Next.js Public (must duplicate with NEXT_PUBLIC_ prefix) ──
NEXT_PUBLIC_MONAD_RPC_URL=
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_PRIVY_APP_ID=

# ── Agent CLI ─────────────────────────────────────────────
GEMINI_API_KEY=                              # SECRET — Google Gemini API key

# ── NeuroStream SDK ──────────────────────────────────────
NEUROSTREAM_API_URL=                         # Edge Functions base URL (e.g. https://xxx.supabase.co/functions/v1)
NEUROSTREAM_API_KEY=                         # SECRET — ns_live_xxxx (generate from Agent panel)
NEUROSTREAM_GATEWAY_URL=http://localhost:3000 # Gateway URL (Next.js app base URL)

# ── Gateway ──────────────────────────────────────────────
GATEWAY_PRIVATE_KEY=                         # SECRET — Gateway wallet private key (Hardhat Account #3 for dev)
GATEWAY_WALLET_ADDRESS=                      # Gateway wallet address

# ── Misc ───────────────────────────────────────────────────
REPORT_GAS=false                             # Enable Hardhat gas reporter
